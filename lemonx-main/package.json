{
  "name": "my-mastra-app",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "npx tsx src/index.ts",
    "docker:up": "docker compose up --build --abort-on-container-exit --exit-code-from lemon",
    "docker:down": "docker compose down -v",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest"
    

  },
  "dependencies": {
    "@mastra/core": "1.21.0",
    "@mastra/libsql": "1.7.3",
    "@mastra/memory": "1.13.0",
    "@mastra/rag": "2.1.3",
    "dotenv": "17.4.0",
    "express": "^4.21.0",
    "ioredis": "^5.10.1",
    "vitest": "4.1.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
