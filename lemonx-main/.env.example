# Cloudflare Workers AI (for AI agents)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_KEY=your-api-key

# GitHub (required for PR creation)
GITHUB_TOKEN=your-github-token
GITHUB_REPOSITORY=owner/repo
GITHUB_REF=refs/heads/main
GITHUB_SHA=your-commit-sha

# Logging / Debugging
# Set VERBOSE=true or DEBUG=true for detailed logs including prompts, tool calls, full responses
VERBOSE=true
DEBUG=true
